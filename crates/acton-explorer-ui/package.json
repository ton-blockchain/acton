{
  "name": "acton-explorer-ui",
  "version": "1.0.0",
  "private": true,
  "license": "MIT OR Apache-2.0",
  "author": "TON Core",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "tsc --noEmit && vite build && XDG_CONFIG_HOME=../../target/wrangler-config WRANGLER_LOG_PATH=../../target/wrangler-logs wrangler pages functions build functions --outdir dist --build-output-directory dist --compatibility-date 2026-06-18 && mv dist/index.js dist/_worker.js",
    "dev": "vite --port 3007",
    "fmt": "biome format --write .",
    "fmt:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "precommit": "bun fmt && bun lint && bun build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@acton/shared-ui": "workspace:*",
    "@cloudflare/pages-plugin-vercel-og": "^0.1.2",
    "@ton/core": "0.62.0",
    "@ton/crypto": "^3.3.0",
    "@ton/tolk-abi-to-typescript": "^0.5.0",
    "buffer": "^6.0.3",
    "lucide-react": "^0.474.0",
    "qrcode.react": "^4.2.0",
    "react-d3-tree": "^3.6.6",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.15.0",
    "shiki": "^3.22.0",
    "ton-assembly": "^0.6.1",
    "vite-plugin-node-polyfills": "^0.28.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "wrangler": "^4.100.0"
  }
}
