{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@acton/shared-ui": ["../acton-shared-ui/src/index.ts"],
      "@acton/shared-ui/*": ["../acton-shared-ui/*"],
      "@/*": ["../acton-shared-ui/src/*"],
      "@tasm-spec/*": ["../tasm-core/spec/*"]
    },
    "types": ["vite/client", "node"]
  },
  "include": ["src", "functions", "../acton-localnet-ui/src/explorer"]
}
