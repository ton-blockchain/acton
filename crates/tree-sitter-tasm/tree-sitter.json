{
    "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
    "grammars": [
        {
            "name": "tasm",
            "camelcase": "Tasm",
            "title": "TASM",
            "scope": "source.tasm",
            "file-types": ["tasm"],
            "injection-regex": "^tasm$",
            "class-name": "TreeSitterTasm"
        }
    ],
    "metadata": {
        "version": "0.1.0",
        "license": "MIT",
        "description": "TASM grammar for tree-sitter",
        "authors": [
            {
                "name": "TON Core"
            },
            {
                "name": "TON Studio",
                "url": "https://tonstudio.io"
            }
        ],
        "links": {
            "repository": "https://github.com/ton-blockchain/ton-language-server"
        }
    },
    "bindings": {
        "c": true,
        "go": true,
        "java": false,
        "node": true,
        "python": false,
        "rust": true,
        "swift": false,
        "zig": false
    }
}
