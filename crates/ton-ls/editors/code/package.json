{
  "name": "tolk-vscode",
  "displayName": "Tolk, TASM, Fift, TL-B & TOML Support",
  "version": "0.0.1",
  "description": "Language support for Tolk, TASM, Fift, TL-B and Acton.toml",
  "categories": [
    "Programming Languages"
  ],
  "publisher": "petrmakhnev",
  "main": "./out/extension",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "contributes": {
    "configuration": {
      "type": "object",
      "title": "Tolk",
      "properties": {
        "tolk.serverPath": {
          "type": "string",
          "default": "ton-ls",
          "description": "Path to the ton-ls executable"
        },
        "tolk.serverPort": {
          "type": "number",
          "default": 0,
          "description": "Port to connect to for TCP debugging (0 to use executable)"
        }
      }
    },
    "languages": [
      {
        "id": "tolk",
        "aliases": [
          "Tolk"
        ],
        "extensions": [
          ".tolk"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "tasm",
        "aliases": [
          "TASM"
        ],
        "extensions": [
          ".tasm"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "fift",
        "aliases": [
          "Fift"
        ],
        "extensions": [
          ".fif",
          ".fift"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "tlb",
        "aliases": [
          "TL-B"
        ],
        "extensions": [
          ".tlb"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "toml",
        "aliases": [
          "TOML"
        ],
        "filenames": [
          "Acton.toml"
        ]
      }
    ]
  },
  "activationEvents": [
    "onLanguage:tolk",
    "onLanguage:tasm",
    "onLanguage:fift",
    "onLanguage:tlb",
    "onLanguage:toml"
  ],
  "dependencies": {
    "vscode-languageclient": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^18.14.6",
    "@types/vscode": "^1.75.0",
    "typescript": "^4.9.5"
  },
  "engines": {
    "vscode": "^1.75.0"
  }
}
