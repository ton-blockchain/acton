========================================================================
Generic struct with single field: deduce primitive type from alias
========================================================================
struct Foo<T> {
    field: T,
}

type IntFoo = Foo<int>;

fun main() {
    val foo =
//!     ^ IntFoo
        IntFoo { field: 10 };
//!              ^ int

    val res = foo.field;
//!     ^ int
}
