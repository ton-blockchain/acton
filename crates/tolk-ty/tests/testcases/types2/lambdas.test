========================================================================
Lambda param type
========================================================================
fun measure(cb: (int) -> int) {}

fun foo() {
    measure(fun (x) {
        //!      ^ int
    })
}
------------------------------------------------------------------------
ok

========================================================================
Lambda param types
========================================================================
fun measure(cb: (int, slice) -> int) {}

fun foo() {
    measure(fun (
        x,
//!     ^ int
        y,
//!     ^ slice
    ) {
    })
}
------------------------------------------------------------------------
ok

========================================================================
Lambda auto return type
========================================================================
fun measure<T>(cb: () -> T): T {}

fun foo() {
    val a = measure(fun () {
//!     ^ int
        return 10
    })
}
------------------------------------------------------------------------
ok

========================================================================
Lambda nullable auto return type
========================================================================
fun measure<T>(cb: (int) -> T): T {}

fun foo() {
    val a = measure(fun (a) {
//!     ^ int?
        if (a > 10) {
            return null
        }
        return 10
    })
}
------------------------------------------------------------------------
ok

========================================================================
Lambda with never auto return type
========================================================================
fun measure<T>(cb: (int) -> T): T {}

fun foo() {
    val a = measure(fun (a) {
//!     ^ never
        if (a > 10) {
            throw 20
        }
        throw 10
    })
}
------------------------------------------------------------------------
ok

========================================================================
Lambda with generic param type
========================================================================
fun measure<T>(cb: (T) -> void): T {}

fun foo() {
    val a = measure(fun (a: int) {
//!     ^ int
    })
}
------------------------------------------------------------------------
ok

========================================================================
Lambda with generic param type with struct
========================================================================
struct S {
    x: int
}

fun measure<T>(cb: (T) -> void): T {}

fun foo() {
    val a = measure(fun (a: S) {
//!     ^ S
                 a
//!              ^ S
                      .x;
//!                    ^ int
    })
}
------------------------------------------------------------------------
ok

========================================================================
Lambda captures outer local
========================================================================
fun foo() {
    val x = 10
    val f = fun () {
        x
//!     ^ int
    }
}
------------------------------------------------------------------------
ok

========================================================================
Lambda captures outer smart-cast
========================================================================
fun foo(x: int?) {
    if (x != null) {
        val f = fun () {
            x
//!         ^ int
        }
    }
}
------------------------------------------------------------------------
ok

========================================================================
Lambda captures outer parameter
========================================================================
fun foo(x: int) {
    val f = fun () {
        x
//!     ^ int
    }
}
------------------------------------------------------------------------
ok

========================================================================
Lambda captures smart-casted outer local
========================================================================
fun foo() {
    var x: int? = 10
    if (x != null) {
        val f = fun () {
            x
//!         ^ int
        }
    }
}
------------------------------------------------------------------------
ok

========================================================================
Nested lambda captures outer lambda parameter
========================================================================
fun foo() {
    val f = fun (x: int) {
        val g = fun () {
            x
//!         ^ int
        }
        return g
    }
}
------------------------------------------------------------------------
ok
