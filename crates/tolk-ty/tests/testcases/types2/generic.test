========================================================================
Call static method on generic instantiation
========================================================================
struct Generic<T> {
}

fun Generic<T>.foo() {
    return Generic<T> {}
}

fun main() {
    val st = Generic<int>.foo();
    //! ^ Generic<int>
}
------------------------------------------------------------------------
ok

========================================================================
Call static method on generic instantiation 2
========================================================================
struct Generic<T> {
    a: T
}

fun Generic<T>.foo(a: T) {
    return Generic<T> { a }
}

fun foo<T>(a: T) {
    val b = Generic<T>.foo(a);
    //! ^ Generic<T>
    return b
}

fun main() {
    val st = foo(1);
    //! ^ Generic<int>
}
------------------------------------------------------------------------
ok

