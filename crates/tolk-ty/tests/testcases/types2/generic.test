========================================================================
Generic function with no arguments: explicit type argument
========================================================================
fun generic<T>(): T {}

fun main() {
    val foo = generic<int>();
//!     ^ int
}
------------------------------------------------------------------------
ok

========================================================================
Generic function with no arguments: explicit two type arguments and union type
========================================================================
fun generic<T, U>(): T | U {}

fun main() {
    val foo = generic<int, slice>();
//!     ^ int | slice
}
------------------------------------------------------------------------
ok

