========================================================================
Generic function with no arguments: explicit two type arguments and function type
========================================================================
fun generic<T, U>(): (T) -> U {}

fun main() {
    val foo = generic<int, slice>();
//!     ^ (int) -> slice

    val res = foo();
//!     ^ slice
}
------------------------------------------------------------------------
ok

========================================================================
Generic function with single arguments: explicit struct type
========================================================================
struct Foo {
    value: int,
}

fun generic<T>(a: T): T {}

fun main() {
    val foo =
//!     ^ Foo
        generic<Foo>({
//!                  ^ Foo
            value: 10,
//!         ^ int
        });
}
------------------------------------------------------------------------
ok

