========================================================================
Function call
========================================================================
fun foo(): int {}

fun main() {
    val a = foo();
    //! ^ int
}
------------------------------------------------------------------------
ok

========================================================================
Function call with union type
========================================================================
fun foo(): int | bool {}

fun main() {
    val a = foo();
    //! ^ int | bool
}
------------------------------------------------------------------------
ok

========================================================================
Call variable with function name
========================================================================
fun foo(): int | bool {}

fun main() {
    val a = foo;
    //! ^ () -> int | bool

    val res = a();
    //! ^ int | bool
}
------------------------------------------------------------------------
ok

========================================================================
Call variable with function name and infer short struct instance
========================================================================
struct Foo {
    value: int,
}

fun foo(foo: Foo): int | bool {}

fun main() {
    val a = foo;
    //! ^ (Foo) -> int | bool

    val res =
    //! ^ int | bool
        a({
//!       ^ Foo
            value: 10,
//!         ^ int
        });
}
------------------------------------------------------------------------
ok

========================================================================
Function function call
========================================================================
fun getCallable(): () -> int {}

fun main() {
    val foo = getCallable()();
//!     ^ int
}
------------------------------------------------------------------------
ok

========================================================================
Function function call with short instance expression
========================================================================
struct Foo {
    value: int,
}

fun getCallable(): (Foo) -> int {}

fun main() {
    val foo =
//!     ^ int
        getCallable()({
//!                   ^ Foo
            value: 10,
//!         ^ int
        });
}
------------------------------------------------------------------------
ok

