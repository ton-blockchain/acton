========================================================================
Maybe unwrap and chained method call
========================================================================
type Maybe<X> = Value<X> | None

struct (0b0) None

struct (0b1) Value<X> {
    value: X
}

fun Maybe<X>.unwrap(self): X {
    if (self is None) {
        throw 7;
    }
    return self.value;
}

struct Body {
    marker: int
}

struct Message<T> {
    body: T
}

fun Message<T>.loadBody(self): T {
    return self.body;
}

fun main(v: Maybe<Message<Body>>) {
    val body = v.unwrap().loadBody();
//!     ^ Body
    val marker = body.marker;
//!     ^ int
}
------------------------------------------------------------------------
ok

========================================================================
Maybe unwrap after generic method with default type parameter
========================================================================
type Maybe2<X> = Value2<X> | None2

struct (0b0) None2

struct (0b1) Value2<X> {
    value: X
}

fun Maybe2<X>.none(): Maybe2<X> {
    return None2{}
}

fun Maybe2<X>.unwrap(self): X {
    if (self is None2) {
        throw 7;
    }
    return self.value;
}

struct ExternalBody {
    marker: int,
}

struct Message2<TBody> {
    body: TBody,
}

fun Message2<TBody>.loadBody(self): TBody {
    return self.body;
}

type SendResultList2 = array<tuple>

fun SendResultList2.findExternalOutMessage<TBody = never>(self): Maybe2<Message2<TBody>> {
    return Maybe2<Message2<TBody>>.none();
}

fun main(res: SendResultList2) {
    val ext = res.findExternalOutMessage<ExternalBody>();
//!     ^ Maybe2<Message2<ExternalBody>>
    val maybeMsg = ext;
//!     ^ Maybe2<Message2<ExternalBody>>
    val unwrapped = maybeMsg.unwrap();
//!     ^ Message2<ExternalBody>
    val body = unwrapped.loadBody();
//!     ^ ExternalBody
    val marker = body.marker;
//!     ^ int
}
------------------------------------------------------------------------
ok

========================================================================
Negative is-check with never call narrows after if
========================================================================
struct Assert

fun Assert.fail(): never {
    throw 0;
}

struct (0b0) AccountNone
struct (0b1) AccountInfo {
    storage: AccountStorage
}
type Account = AccountNone | AccountInfo

struct (0b00) AccountStateUninit
struct (0b1) AccountStateActive {
    marker: int,
}
struct (0b01) AccountStateFrozen {
    hash: int,
}
type AccountState = AccountStateUninit | AccountStateActive | AccountStateFrozen

struct AccountStorage {
    state: AccountState,
}

fun main(account: Account) {
    if (account !is AccountInfo) {
        Assert.fail();
    }

    var info = account;
    if (info.storage.state !is AccountStateActive) {
        Assert.fail();
    }

    var active = info.storage.state;
//!     ^ AccountStateActive
}
------------------------------------------------------------------------
ok

========================================================================
Match smartcast on self field for generic Either
========================================================================
struct Cell3<T> {
    value: T
}

fun Cell3<T>.load(self, options: int = 0): T {
    return self.value;
}

type Either3<X, Y> = EitherLeft3<X> | EitherRight3<Y>

struct EitherLeft3<X> {
    value: X
}

struct EitherRight3<X> {
    value: X
}

struct Message3<TBody> {
    body: Either3<TBody, Cell3<TBody>>
}

fun Message3<TBody>.loadBody(self): TBody {
    return match (self.body) {
        EitherLeft3 => self.body.value,
        EitherRight3 => self.body.value.load(0),
    };
}

fun main(m: Message3<int>) {
    val body = m.loadBody();
//!     ^ int
}
------------------------------------------------------------------------
ok

========================================================================
Match smartcast on self field for generic Either with object options
========================================================================
struct UnpackOptions4 {
    assertEndAfterReading: bool
}

struct Cell4<T> {
    value: T
}

fun Cell4<T>.load(self, options: UnpackOptions4 = {}): T {
    return self.value;
}

type Either4<X, Y> = EitherLeft4<X> | EitherRight4<Y>

struct EitherLeft4<X> {
    value: X
}

struct EitherRight4<X> {
    value: X
}

struct Info4 {
    id: int
}

struct Message4<TBody, TInfo> {
    info: TInfo
    body: Either4<TBody, Cell4<TBody>>
}

fun Message4<TBody, TInfo>.loadBody(self): TBody {
    return match (self.body) {
        EitherLeft4 => self.body.value,
        EitherRight4 => self.body.value.load({ assertEndAfterReading: false }),
    };
}

fun main(m: Message4<int, Info4>) {
    val body = m.loadBody();
//!     ^ int
}
------------------------------------------------------------------------
ok

========================================================================
Static generic alias method on instantiated alias with type parameter
========================================================================
type Either5<X, Y> = EitherLeft5<X> | EitherRight5<Y>

struct EitherLeft5<X> {
    value: X
}

struct EitherRight5<X> {
    value: X
}

fun Either5<X, Y>.right(value: Y) {
    return EitherRight5 { value };
}

struct Cell5<T> {
    value: T
}

fun T.toCell(self): Cell5<T> {
    return Cell5 { value: self };
}

struct Out5<TBody> {
    body: Either5<TBody, Cell5<TBody>>
}

fun wrap5<TBody>(body: TBody): Out5<TBody> {
    val wrapped = Either5<TBody, Cell5<TBody>>.right(body.toCell());
//!     ^ EitherRight5<Cell5<TBody>>
    return Out5<TBody> {
        body: wrapped,
    };
}

fun main() {
    val out = wrap5(10);
//!     ^ Out5<int>
}
------------------------------------------------------------------------
ok
