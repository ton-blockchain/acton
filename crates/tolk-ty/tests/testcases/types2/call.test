Generic method call
========================================================================
struct Cell2<T> {
    private readonly tvmCell: cell
}

@pure
fun Cell2<T>.load2(self, options: UnpackOptions = {}): T
    builtin

fun main() {
    val cell: Cell2<int>;
//!     ^ Cell2<int>
    val res = cell.load2();
//!     ^ int
}
------------------------------------------------------------------------
ok
