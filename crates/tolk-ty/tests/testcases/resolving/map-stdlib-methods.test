stdlib map methods on concrete map
========================================================================
fun main() {
    var m = createEmptyMap<int32, cell>();
    val c = beginCell().endCell();

    val first = m.<caret>findFirst();
    val last = m.<caret>findLast();

    m.<caret>toLowLevelDict();
    m.<caret>isEmpty();
    m.<caret>exists(1);
    m.<caret>get(1);
    m.<caret>mustGet(1);
    m.<caret>set(1, c);
    m.<caret>setAndGetPrevious(1, c);
    m.<caret>replaceIfExists(1, c);
    m.<caret>replaceAndGetPrevious(1, c);
    m.<caret>addIfNotExists(1, c);
    m.<caret>addOrGetExisting(1, c);
    m.<caret>delete(1);
    m.<caret>deleteAndGetDeleted(1);
    m.<caret>findKeyGreater(1);
    m.<caret>findKeyGreaterOrEqual(1);
    m.<caret>findKeyLess(1);
    m.<caret>findKeyLessOrEqual(1);
    m.<caret>iterateNext(first);
    m.<caret>iteratePrev(last);
}
