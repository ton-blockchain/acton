========================================================================
stdlib map methods inside alias methods (lib-style wrappers)
========================================================================
type Config = map<uint32, cell>

fun Config.setParamRaw(mutate self, index: uint32, data: cell) {
    self.<caret>set(index, data);
}

fun Config.getParamRaw(self, index: uint32): cell {
    return self.<caret>get(index).loadValue();
}

fun Config.hasParam(self, index: uint32): bool {
    return self.<caret>exists(index);
}
