    "d3-selection": "^3.0.0",
    "react-d3-tree": "^3.6.6",
    "react-icons": "^5.5.0",
    "shiki": "^3.22.0",
    "vite-plugin-node-polyfills": "^0.28.0"
  },
  "devDependencies": {
    "@types/d3-hierarchy": "^1.1.11",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
