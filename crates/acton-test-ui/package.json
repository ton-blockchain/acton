  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "dev": "vite",
    "fmt": "prettier --write -l --cache .",
    "fmt:check": "prettier --check --cache .",
    "lint": "eslint --max-warnings 0 . --cache",
    "lint:fix": "eslint --fix . --cache",
    "precommit": "bun fmt && bun lint && bun build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@acton/shared-ui": "workspace:*",
    "@ton/core": "0.62.0",
    "bignumber.js": "^9.3.1",
    "buffer": "^6.0.3",
    "d3-hierarchy": "^1.1.9",
    "gen-typescript-from-tolk-dev": "^0.4.1",
    "react-d3-tree": "^3.6.6",
    "react-icons": "^5.5.0",
    "shiki": "^3.22.0",
    "vite-plugin-node-polyfills": "^0.24.0"
  },
  "devDependencies": {
    "@types/d3-hierarchy": "^1.1.11",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.0"
  }
