{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Acton Configuration Schema",
  "description": "JSON schema for Acton.toml configuration file",
  "type": "object",
  "required": [
    "package"
  ],
  "properties": {
    "build": {
      "description": "Default settings for the build command",
      "allOf": [
        {
          "$ref": "#/definitions/BuildSettings"
        }
      ]
    },
    "contracts": {
      "description": "Definition of contracts in the project",
      "allOf": [
        {
          "$ref": "#/definitions/ContractsConfig"
        }
      ]
    },
    "fmt": {
      "description": "Settings for the Tolk code formatter",
      "allOf": [
        {
          "$ref": "#/definitions/FmtSettings"
        }
      ]
    },
    "lint": {
      "description": "Linter configuration for the project",
      "allOf": [
        {
          "$ref": "#/definitions/LintConfig"
        }
      ]
    },
    "litenode": {
      "description": "Default settings for `acton litenode` commands",
      "allOf": [
        {
          "$ref": "#/definitions/LitenodeSettings"
        }
      ]
    },
    "mappings": {
      "description": "Path mappings for Tolk compiler imports (e.g., 'core' = './foo/core' maps to '@core/...')",
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "networks": {
      "description": "Custom network configurations",
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/CustomNetworkConfig"
      }
    },
    "package": {
      "description": "Package metadata for the Acton project",
      "allOf": [
        {
          "$ref": "#/definitions/PackageConfig"
        }
      ]
    },
    "scripts": {
      "description": "Custom scripts that can be run with 'acton run'",
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "test": {
      "description": "Default settings for the test runner",
      "allOf": [
        {
          "$ref": "#/definitions/TestSettings"
        }
      ]
    },
    "wrappers": {
      "description": "Default settings for wrapper generation",
      "allOf": [
        {
          "$ref": "#/definitions/WrappersConfig"
        }
      ]
    }
  },
  "definitions": {
    "BuildSettings": {
      "description": "Default settings for the build command",
      "type": "object",
      "properties": {
        "gen-dir": {
          "description": "Directory where generated dependency files are saved",
          "type": "string"
        },
        "out-dir": {
          "description": "Directory where JSON build artifacts are saved",
          "type": "string"
        },
        "output-fift": {
          "description": "Directory where per-contract compiled Fift files are saved",
          "type": "string"
        }
      }
    },
    "CheckOutputFormat": {
      "description": "Output format for `acton check` diagnostics",
      "type": "string",
      "enum": [
        "plain",
        "json",
        "sarif",
        "github",
        "gitlab"
      ]
    },
    "ContractConfig": {
      "type": "object",
      "required": [
        "name",
        "src"
      ],
      "properties": {
        "name": {
          "description": "Human-readable name of the contract",
          "type": "string"
        },
        "src": {
          "description": "Path to the contract source (.tolk) or precompiled (.boc) file",
          "type": "string"
        },
        "depends": {
          "description": "Dependencies of this contract",
          "type": "array",
          "items": {
            "$ref": "#/definitions/ContractDependency"
          }
        },
        "output": {
          "description": "Path where the compiled .boc should be saved",
          "type": "string"
        }
      }
    },
    "ContractDependency": {
      "anyOf": [
        {
          "description": "Name of the contract to depend on (simple format)",
          "type": "string"
        },
        {
          "description": "Detailed dependency configuration",
          "type": "object",
          "required": [
            "name"
          ],
          "properties": {
            "name": {
              "description": "Name of the contract to depend on",
              "type": "string"
            },
            "kind": {
              "description": "Dependency type",
              "default": "embed_code",
              "allOf": [
                {
                  "$ref": "#/definitions/DependencyKind"
                }
              ]
            },
            "function": {
              "description": "Custom name for the generated code function",
              "type": "string"
            },
            "path": {
              "description": "Custom output path for the generated code file",
              "type": "string"
            }
          }
        }
      ]
    },
    "ContractsConfig": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/ContractConfig"
      }
    },
    "CustomNetworkApiConfig": {
      "type": "object",
      "properties": {
        "v2": {
          "description": "The URL for the TonCenter API v2. For localnet this defaults to http://localhost:<litenode.port>/api/v2 (port 5411 fallback)",
          "type": "string"
        },
        "v3": {
          "description": "The URL for the TonCenter API v3. For localnet this defaults to http://localhost:<litenode.port>/api/v3 (port 5411 fallback)",
          "type": "string"
        }
      }
    },
    "CustomNetworkConfig": {
      "type": "object",
      "properties": {
        "api": {
          "allOf": [
            {
              "$ref": "#/definitions/CustomNetworkApiConfig"
            }
          ]
        },
        "explorer": {
          "description": "Base URL used to build transaction links for this network. Acton appends /tx/<hash> automatically (adds /tx/ if missing). If omitted, links are derived from api.v2",
          "type": "string"
        }
      }
    },
    "DependencyKind": {
      "description": "Dependency type",
      "type": "string",
      "enum": [
        "embed_code",
        "library_ref"
      ]
    },
    "FmtSettings": {
      "description": "Settings for the Tolk code formatter",
      "type": "object",
      "properties": {
        "ignore": {
          "description": "Glob patterns to ignore from formatting",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "separate-import-groups": {
          "description": "Insert an empty line between import groups (@stdlib, @acton, @<other>, ../, ./)",
          "type": "boolean",
          "default": false
        },
        "width": {
          "description": "Maximum line width for formatting",
          "type": "integer",
          "default": 100,
          "minimum": 1
        }
      }
    },
    "LintConfig": {
      "description": "Linter configuration for the project",
      "type": "object",
      "properties": {
        "exclude": {
          "description": "Glob patterns for files to exclude from lint diagnostics",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "max-warnings": {
          "description": "Maximum allowed warning count before `acton check` exits with a non-zero code",
          "type": "integer",
          "minimum": 0
        },
        "output-format": {
          "description": "Output format for `acton check` diagnostics",
          "allOf": [
            {
              "$ref": "#/definitions/CheckOutputFormat"
            }
          ]
        },
        "rules": {
          "description": "Lint rules and contract-specific overrides",
          "allOf": [
            {
              "$ref": "#/definitions/LintRules"
            }
          ]
        }
      }
    },
    "LintEntry": {
      "anyOf": [
        {
          "description": "Global lint level for a rule",
          "allOf": [
            {
              "$ref": "#/definitions/LintLevel"
            }
          ]
        },
        {
          "description": "Contract-specific lint overrides",
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/LintLevel"
          }
        }
      ]
    },
    "LintLevel": {
      "type": "string",
      "enum": [
        "allow",
        "warn",
        "deny"
      ]
    },
    "LintRules": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/LintEntry"
      }
    },
    "LitenodeSettings": {
      "description": "Default settings for `acton litenode` commands",
      "type": "object",
      "properties": {
        "accounts": {
          "description": "Wallet names from [wallets] that are automatically funded and deployed on `acton litenode start`",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fork-block-number": {
          "description": "Block sequence number used by `acton litenode start` when forking from historical state",
          "type": "integer",
          "minimum": 0
        },
        "fork-net": {
          "description": "Network to fork from used by `acton litenode start`",
          "type": "string"
        },
        "port": {
          "description": "Litenode port used by `acton litenode` commands",
          "type": "integer",
          "default": 3000,
          "minimum": 0,
          "maximum": 65535
        },
        "rate-limit": {
          "description": "Maximum number of API requests per second served by LiteNode `/api` endpoints",
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "MutationConfig": {
      "description": "Configuration for mutation testing",
      "type": "object",
      "properties": {
        "disable-rules": {
          "description": "List of mutation rules to disable",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "PackageConfig": {
      "description": "Package metadata for the Acton project",
      "type": "object",
      "required": [
        "name",
        "description",
        "version"
      ],
      "properties": {
        "description": {
          "description": "A short description of the project",
          "type": "string"
        },
        "name": {
          "description": "The name of the project",
          "type": "string"
        },
        "version": {
          "description": "The current version of the project",
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-.*)?$"
        },
        "repository": {
          "description": "The URL of the project's repository",
          "type": "string"
        },
        "license": {
          "description": "The project's license (e.g., MIT, Apache-2.0)",
          "type": "string"
        }
      }
    },
    "TestSettings": {
      "description": "Default settings for the test runner",
      "type": "object",
      "properties": {
        "filter": {
          "description": "Regex pattern to filter test names",
          "type": "string"
        },
        "reporter": {
          "description": "List of test reporters to use",
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "console",
              "teamcity",
              "junit",
              "dot"
            ]
          }
        },
        "debug": {
          "description": "Enable debug mode for tests",
          "type": "boolean"
        },
        "debug-port": {
          "description": "Port for the debug server",
          "type": "integer",
          "default": 12345,
          "minimum": 0,
          "maximum": 65535
        },
        "backtrace": {
          "description": "Enable stack traces (e.g., 'full')",
          "type": "string"
        },
        "coverage": {
          "description": "Enable code coverage reporting",
          "type": "boolean"
        },
        "coverage-format": {
          "description": "Format for coverage reports (e.g., 'lcov')",
          "type": "string",
          "default": "lcov"
        },
        "coverage-file": {
          "description": "Path to save the coverage report",
          "type": "string"
        },
        "exclude": {
          "description": "Glob patterns to exclude from testing",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "include": {
          "description": "Glob patterns to include in testing",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "junit-path": {
          "description": "Directory for JUnit XML reports",
          "type": "string"
        },
        "junit-merge": {
          "description": "Merge all test suites into a single JUnit file",
          "type": "boolean"
        },
        "fork-net": {
          "description": "Network to fork for testing (e.g., 'mainnet', 'testnet')",
          "type": "string"
        },
        "api-key": {
          "description": "API key for the network provider when forking",
          "type": "string"
        },
        "fork-block-number": {
          "description": "Specific block number to fork from",
          "type": "integer",
          "minimum": 0
        },
        "mutation": {
          "description": "Configuration for mutation testing",
          "allOf": [
            {
              "$ref": "#/definitions/MutationConfig"
            }
          ]
        },
        "fail-fast": {
          "description": "Stop test execution after the first failure",
          "type": "boolean"
        },
        "fail-on-diff": {
          "description": "Exit with non-zero code when gas profiling differs from baseline snapshot",
          "type": "boolean"
        }
      }
    },
    "TolkWrapperSettings": {
      "description": "Default settings for Tolk wrapper generation",
      "type": "object",
      "properties": {
        "output-dir": {
          "description": "Directory where `acton wrapper` writes generated Tolk wrappers by default",
          "type": "string"
        },
        "generate-test": {
          "description": "Generate a Tolk test stub by default for `acton wrapper`",
          "type": "boolean"
        },
        "test-output-dir": {
          "description": "Directory where generated Tolk test stubs are written by default",
          "type": "string"
        }
      }
    },
    "TypescriptWrapperSettings": {
      "description": "Default settings for TypeScript wrapper generation",
      "type": "object",
      "properties": {
        "output-dir": {
          "description": "Directory where `acton wrapper --ts` writes generated TypeScript wrappers by default",
          "type": "string"
        }
      }
    },
    "WrappersConfig": {
      "description": "Default settings for wrapper generation",
      "type": "object",
      "properties": {
        "tolk": {
          "description": "Default settings for Tolk wrapper generation",
          "allOf": [
            {
              "$ref": "#/definitions/TolkWrapperSettings"
            }
          ]
        },
        "typescript": {
          "description": "Default settings for TypeScript wrapper generation",
          "allOf": [
            {
              "$ref": "#/definitions/TypescriptWrapperSettings"
            }
          ]
        }
      }
    }
  }
}
