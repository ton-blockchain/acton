[package]
name = "my-acton-project"
description = "A TON blockchain project"
version = "0.1.0"
license = "MIT"

[contracts.my_contract]
display-name = "My Contract"
src = "contracts/my_contract.tolk"
depends = []

[fmt]
width = 100
ignore = []

[mappings]
acton = ".acton"
contracts = "contracts"
gen = "gen"
tests = "tests"
wrappers = "wrappers"
