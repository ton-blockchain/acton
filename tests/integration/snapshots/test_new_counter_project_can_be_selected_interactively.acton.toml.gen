[package]
name = "interactive-selected-counter"
description = "interactive selected counter description"
version = "0.1.0"
license = "MIT"

[contracts.counter]
name = "Counter"
src = "contracts/counter.tolk"
depends = []

[test]

[fmt]
width = 100
ignore = []

[scripts]
deploy-emulation = "acton script scripts/deploy.tolk"
deploy-testnet = "acton script scripts/deploy.tolk --broadcast --net testnet"

[mappings]
acton = ".acton"
contracts = "contracts"
gen = "gen"
tests = "tests"
wrappers = "tests/wrappers"

# Check full Acton.toml reference and all available keys:
# [ACTON_DOCS_URL]/acton-toml
