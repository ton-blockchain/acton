[package]
name = "git-init-failure-project"
description = "git init failure description"
version = "0.1.0"
license = "MIT"

[contracts.empty]
name = "Empty"
src = "contracts/contract.tolk"
depends = []

[test]

[fmt]
width = 100
ignore = []

[scripts]
deploy-emulation = "acton script scripts/deploy.tolk"
deploy-testnet = "acton script scripts/deploy.tolk --broadcast --net testnet"

[mappings]
acton = ".acton"
contracts = "contracts"
gen = "gen"
tests = "tests"
wrappers = "tests/wrappers"
