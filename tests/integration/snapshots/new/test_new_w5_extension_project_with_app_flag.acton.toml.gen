[package]
name = "W5 Extension App Project"
description = "w5-extension app description"
version = "0.1.0"
license = "MIT"

[toolchain]
acton = "[ACTON_VERSION]"

[contracts.SimpleExtension]
display-name = "SimpleExtension"
src = "contracts/src/SimpleExtension.tolk"
depends = []

[contracts.WalletV5]
display-name = "WalletV5"
src = "contracts/src/walletv5/WalletV5.tolk"
depends = []

[test]

[fmt]
width = 100
ignore = []

[scripts]
delete-extension = "acton script contracts/scripts/delete-extension.tolk --net testnet"
deploy-emulation = "acton script contracts/scripts/deploy.tolk"
deploy-testnet = "acton script contracts/scripts/deploy.tolk --net testnet"
install-extension = "acton script contracts/scripts/install-extension.tolk --net testnet"

[import-mappings]
acton = ".acton"
contracts = "contracts/src"
gen = "gen"
tests = "contracts/tests"
wrappers = "contracts/wrappers"

# Check full Acton.toml reference and all available keys:
# [ACTON_DOCS_URL]/acton-toml
