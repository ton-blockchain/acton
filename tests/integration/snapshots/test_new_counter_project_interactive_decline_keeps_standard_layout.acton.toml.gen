[package]
name = "interactive-counter"
description = "interactive description"
version = "0.1.0"
license = "MIT"

[contracts.Counter]
display-name = "Counter"
src = "contracts/Counter.tolk"
depends = []

[test]

[lint]
exclude = ["**/*.gen.tolk"]

[fmt]
width = 100
ignore = ["**/*.gen.tolk"]

[scripts]
deploy-emulation = "acton script scripts/deploy.tolk"
deploy-testnet = "acton script scripts/deploy.tolk --net testnet"

[import-mappings]
acton = ".acton"
contracts = "contracts"
gen = "gen"
tests = "tests"
wrappers = "wrappers"

# Check full Acton.toml reference and all available keys:
# [ACTON_DOCS_URL]/acton-toml
